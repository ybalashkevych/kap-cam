{
  "name": "kap-cam",
  "version": "1.1.1",
  "description": "Loom-like webcam overlay for Kap (maintained fork: Studio Display, zoom, universal macOS binaries)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ybalashkevych/kap-cam.git"
  },
  "license": "MIT",
  "author": "Yurii Balashkevych",
  "keywords": [
    "kap-plugin",
    "camera",
    "webcam",
    "recording",
    "loom"
  ],
  "kap": {
    "version": ">=3.3.2"
  },
  "scripts": {
    "build": "bash binaries/build.sh",
    "build-devices": "bash -c 'MACOSX_DEPLOYMENT_TARGET=11.0 swiftc -O -o ./binaries/devices ./binaries/devices.swift'",
    "build-permissions": "bash -c 'MACOSX_DEPLOYMENT_TARGET=11.0 swiftc -O -o ./binaries/permissions ./binaries/permissions.swift'"
  },
  "peerDependencies": {
    "electron": "*"
  },
  "dependencies": {
    "electron-util": "^0.14.2",
    "execa": "^4.0.3"
  }
}
